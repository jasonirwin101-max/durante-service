# tracking SPA (Netlify). Leave unset to fall back to BASE_URL.
API_PUBLIC_URL=https://durante-service-production.up.railway.app
OFFICE_DASHBOARD_URL=https://durante-office.netlify.app
JWT_SECRET=
JWT_EXPIRES_IN=8h
NODE_ENV=development

# DURANTE INFO
